# Version to deploy (used by deploy.sh)
VERSION=v0.10

# Google Cloud
PROJECT_ID=your-gcp-project-id
REGION=europe-west1

# Cloud Run service names
MCP_SERVICE_NAME=tlbrain-mcp
VECTOR_SYNC_SERVICE_NAME=tlbrain-vector-sync

# Runtime
PORT=8080
ENVIRONMENT=dev  # dev | prod

# Google Drive
# URL of the root folder containing client subfolders with transcripts
ROOT_FOLDER_URL=https://drive.google.com/drive/folders/YOUR_FOLDER_ID

# Qdrant Cloud
QDRANT_URL=https://YOUR_CLUSTER_ID.REGION.gcp.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=TLBrain

# Gemini
GEMINI_API_KEY=your-gemini-api-key

# Retrieval
RETRIEVAL_TOP_K=15
RETRIEVAL_SCORE_THRESHOLD=0.6

# MCP server auth — Google OAuth 2.0
# Only this email is allowed to access the MCP server.
# Leave empty to disable authentication (open access).
ALLOWED_EMAIL=you@example.com

# Cloud Tasks
VECTOR_SYNC_QUEUE=tlbrain-vector-sync-queue
CLOUD_TASKS_MAX_CONCURRENT=2

# Cloud Scheduler — how often Checker scans Google Drive for changes.
# This controls how quickly new or updated transcripts appear in the knowledge base.
# Default: every 15 minutes. Minimum recommended: 5 minutes (Drive API quota).
# Examples:
#   "*/5 * * * *"  — every 5 minutes (fast updates, higher API usage)
#   "*/15 * * * *" — every 15 minutes (default, good balance)
#   "0 * * * *"    — every hour
#   "0 4 * * *"    — once a day at 4am (low cost, slow updates)
VECTOR_SYNC_CHECKER_SCHEDULE="*/15 * * * *"

# TL;DV connector
TLDV_API_KEY=your-tldv-api-key
TLDV_IMPORT_SERVICE_NAME=tlbrain-tldv-import
TLDV_IMPORT_QUEUE=tlbrain-tldv-import-queue
TLDV_RECONCILIATION_FUNCTION_NAME=tlbrain-tldv-reconciliation
TLDV_RECONCILIATION_SCHEDULE="0 3 * * *"

# Google OAuth (for Drive write access from import service)
# Get client_id and client_secret from Google Cloud Console → OAuth 2.0 Client IDs
# GOOGLE_REFRESH_TOKEN is filled automatically by setup_tokens.py
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=
