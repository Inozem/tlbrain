FROM python:3.12-slim

WORKDIR /app

COPY requirements-common.txt /app/requirements-common.txt
COPY core/gemini/requirements.txt /app/core/gemini/requirements.txt
COPY core/qdrant/requirements.txt /app/core/qdrant/requirements.txt
COPY core/google_drive/requirements.txt /app/core/google_drive/requirements.txt
COPY core/utils/requirements.txt /app/core/utils/requirements.txt
COPY services/mcp/requirements.txt /app/services/mcp/requirements.txt

RUN pip install --no-cache-dir -r /app/services/mcp/requirements.txt

RUN python -c "from fastembed import SparseTextEmbedding; SparseTextEmbedding(model_name='Qdrant/bm25')"

COPY core/__init__.py /app/core/__init__.py
COPY core/config.py /app/core/config.py
COPY core/utils /app/core/utils
COPY core/gemini /app/core/gemini
COPY core/qdrant /app/core/qdrant
COPY core/retrieval /app/core/retrieval
COPY core/google_drive /app/core/google_drive
COPY services/mcp /app/services/mcp

ENV PYTHONUNBUFFERED=1
ENV PORT=8080

CMD ["python", "-m", "uvicorn", "services.mcp.app.main:app", "--host", "0.0.0.0", "--port", "8080"]
