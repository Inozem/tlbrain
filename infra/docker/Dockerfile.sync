FROM python:3.12-slim

WORKDIR /app

COPY requirements-common.txt /app/requirements-common.txt
COPY services/sync/requirements.txt /app/requirements.txt

RUN pip install --no-cache-dir -r /app/requirements.txt

COPY core /app/core
COPY services/sync /app/services/sync

ENV PYTHONUNBUFFERED=1
ENV PORT=8080

CMD ["python", "-m", "uvicorn", "services.sync.app.main:app", "--host", "0.0.0.0", "--port", "8080"]
