FROM python:3.12-slim

WORKDIR /app

COPY requirements-common.txt /app/requirements-common.txt
COPY core/utils/requirements.txt /app/core/utils/requirements.txt
COPY core/google_drive/requirements.txt /app/core/google_drive/requirements.txt
COPY services/connectors/tldv/import_service/requirements.txt /app/services/connectors/tldv/import_service/requirements.txt

RUN pip install --no-cache-dir -r /app/services/connectors/tldv/import_service/requirements.txt

COPY services/connectors/tldv/import_service/app /app/app
COPY services/connectors/tldv/tldv_client.py /app/tldv_client.py
COPY core/ /app/core/

ENV PYTHONUNBUFFERED=1
ENV PORT=8080

CMD ["python", "-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8080"]
